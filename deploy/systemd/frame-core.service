[Unit]
Description=Picture Frame core service (HTTP API, CDP, scheduler, updater)
After=network.target
Wants=network.target

[Service]
Type=simple
User=frame
Group=frame
WorkingDirectory=/opt/frame/current
Environment=NODE_ENV=production
Environment=FRAME_CONFIG=/etc/frame/frame.yaml
Environment=FRAME_STATE_DIR=/opt/frame/state
Environment=FRAME_RELEASES_DIR=/opt/frame/releases
Environment=FRAME_RUNTIME_DIR=/run/frame
# Cage launches its own chromium (see deploy/launch-chromium.sh).
# frame-core does not currently have a way to spawn a chromium into the
# existing cage Wayland session, so the in-process CDP launcher is
# disabled here. URL-screen / screenshot-transition features are skipped.
Environment=FRAME_DISABLE_CDP=1
ExecStart=/usr/bin/node /opt/frame/current/core/dist/index.js
Restart=on-failure
RestartSec=3
LimitNOFILE=8192

# Create /run/frame on each start (tmpfs clears it on reboot); systemd makes
# this before the namespace is set up, so it's safe to reference below.
RuntimeDirectory=frame
RuntimeDirectoryMode=0755

# Hardening (the Wayland session lives in frame-kiosk; core only needs files + net)
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=read-only
ReadWritePaths=/opt/frame /etc/frame /var/log
PrivateTmp=true

[Install]
WantedBy=multi-user.target
