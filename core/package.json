    "chokidar": "^4.0.1",
    "chrome-remote-interface": "^0.33.2",
    "cron-parser": "^4.9.0",
    "fastify": "^5.0.0",
    "@fastify/websocket": "^11.0.1",
    "@fastify/static": "^8.0.1",
    "mqtt": "^5.10.1",
    "pino": "^9.5.0",
    "tar": "^7.4.3",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
